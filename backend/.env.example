# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Auth ────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY=7d

# ── AI (Sarvam — primary AI provider) ────────────────────────────────────────
# Get your key at https://www.sarvam.ai
SARVAM_API_KEY=sk_your_sarvam_api_key_here
# GEMINI_API_KEY no longer used (migrated to Sarvam AI)

# ── Database (MongoDB) ────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/rayeva_ai

# ── Seed (optional overrides) ────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@rayeva.ai
SEED_ADMIN_PASS=Admin@1234

# ── Cache ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
